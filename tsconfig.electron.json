{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "allowImportingTsExtensions": false,
        "baseUrl": "./electron",
        "lib": ["ES2022"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "noEmit": false,
        "outDir": "./dist-electron",
        "paths": {},
        "rootDir": "./electron",
        "sourceMap": true,
        "types": ["node", "electron"]
    },
    "include": ["electron/**/*.ts"]
}
